<!DOCTYPE html>
<html>
<head>
    <title>Color Trading Game</title>
    <style>
        body {
            text-align: center;
            font-family: Arial;
            background-color: #f4f4f4;
        }

        h1 {
            margin-top: 20px;
        }

        #score {
            font-size: 20px;
            margin: 10px;
        }

        .colors {
            display: flex;
            justify-content: center;
            margin-top: 30px;
        }

        .box {
            width: 100px;
            height: 100px;
            margin: 15px;
            cursor: pointer;
            border-radius: 10px;
            border: 3px solid black;
        }

        #targetColor {
            font-size: 24px;
            margin-top: 20px;
            font-weight: bold;
        }
    </style>
</head>
<body>

<h1>🎨 Color Trading Game</h1>
<div id="score">Money: ₹0</div>
<div id="targetColor">Target: </div>

<div class="colors">
    <div class="box" style="background:red" onclick="checkColor('red')"></div>
    <div class="box" style="background:blue" onclick="checkColor('blue')"></div>
    <div class="box" style="background:green" onclick="checkColor('green')"></div>
    <div class="box" style="background:yellow" onclick="checkColor('yellow')"></div>
</div>

<script>
    let money = 0;
    let colors = ['red', 'blue', 'green', 'yellow'];
    let currentColor = '';

    function generateColor() {
        let randomIndex = Math.floor(Math.random() * colors.length);
        currentColor = colors[randomIndex];
        document.getElementById("targetColor").innerText = "Target: " + currentColor.toUpperCase();
    }

    function checkColor(selectedColor) {
        if (selectedColor === currentColor) {
            money += 100;
            alert("Correct! +₹100");
        } else {
            money -= 50;
            alert("Wrong! -₹50");
        }

        document.getElementById("score").innerText = "Money: ₹" + money;

        if (money >= 1000) {
            alert("🎉 You Won the Game!");
            money = 0;
        }

        generateColor();
    }

    generateColor();
</script>

</body>
</html>
